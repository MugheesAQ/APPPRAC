datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

// User model supporting authentication and roles
model User {
  id           String        @id @default(uuid())
  email        String        @unique
  password     String
  name         String
  role         Role          @default(Citizen)
  phone        String?
  nric         String?       @unique
  address      String?
  avatarUrl    String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  applications Application[]
  notifications Notification[]
  auditLogs    AuditLog[]

  @@index([email])
}

enum Role {
  Citizen
  Officer
  Admin
}

// Service model for the catalog of public applications
model Service {
  id            String        @id @default(uuid())
  code          String        @unique // e.g., ICA-101
  name          String
  department    String
  description   String
  requirements  String[]      // List of strings representing mandatory documents
  estimatedDays Int
  fee           Float
  popularity    Int           @default(0)
  createdAt     DateTime      @default(now())

  applications  Application[]

  @@index([code])
}

// Application model representing user requests
model Application {
  id           String        @id @default(uuid())
  serviceId    String
  service      Service       @relation(fields: [serviceId], references: [id])
  citizenId    String
  citizen      User          @relation(fields: [citizenId], references: [id], onDelete: Cascade)
  status       Status        @default(Submitted)
  formData     Json          // Flexible key-value structured data
  remarks      String        @default("Received and logged in central government queue.")
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  documents    Document[]
  statusLogs   StatusLog[]

  @@index([citizenId])
  @@index([status])
}

enum Status {
  Submitted
  Under_Review
  Processing
  Approved
  Rejected
}

// Document model for file attachments
model Document {
  id            String      @id @default(uuid())
  name          String
  type          String
  url           String
  applicationId String
  application   Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  uploadedAt    DateTime    @default(now())

  @@index([applicationId])
}

// Log history of changes in status
model StatusLog {
  id            String      @id @default(uuid())
  status        Status
  remarks       String
  applicationId String
  application   Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  date          DateTime    @default(now())

  @@index([applicationId])
}

// User Notifications for in-app messaging alerts
model Notification {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String
  message   String
  read      Boolean  @default(false)
  type      String   @default("info") // e.g., info, success, warning
  createdAt DateTime @default(now())

  @@index([userId, read])
}

// Security Audit Log for continuous activity logs
model AuditLog {
  id        String   @id @default(uuid())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  userEmail String
  action    String
  ipAddress String
  timestamp DateTime @default(now())

  @@index([timestamp])
}
